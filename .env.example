# ----- Backend -----
# พอร์ตที่ Express จะรัน (production และ dev backend)
PORT=3000

# Path ของไฟล์ SQLite (default = ./data/foodpos.db)
# DB_PATH=./data/foodpos.db

# URL public สำหรับฝัง QR Code (ต้องเป็น HTTPS ของ Cloudflare Tunnel)
# ถ้าไม่ตั้ง: จะใช้ host จาก request (เหมาะกับ localhost ตอน dev)
# ตัวอย่าง: https://abc-xyz.trycloudflare.com
PUBLIC_BASE_URL=

# ----- Frontend (dev only) -----
# Target ที่ Vite จะ proxy /api ไป (default http://localhost:3000)
# VITE_API_TARGET=http://localhost:3000
