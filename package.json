{
  "name": "foodpos-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c yellow,cyan \"npm run server:dev\" \"vite\"",
    "dev:vite": "vite",
    "server:dev": "nodemon --watch server server/index.js",
    "server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "init-db": "node server/init-db.js",
    "test": "node --test server/lib/loyverse.test.js server/lib/loyverseSync.test.js server/lib/hash.test.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "android:sync": "vite build && cap sync android",
    "android:open": "cap open android",
    "android:build": "vite build && cap sync android && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.14.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.12"
  }
}
